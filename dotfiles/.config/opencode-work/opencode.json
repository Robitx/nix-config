{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "github-copilot"
  ],
  "model": "github-copilot/claude-sonnet-4.5",
  "small_model": "github-copilot/gpt-5-mini",
  "agent": {
    "build": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "general": {
      "model": "github-copilot/gpt-5-mini"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--executable-path=/run/current-system/sw/bin/google-chrome"]
    }
  }
}
